# VentureX environment variables
# Copy to .env.local and fill in. Do not commit .env.local.

# ────────────────────────────────────────────────────────────────────────
# InsForge
# ────────────────────────────────────────────────────────────────────────
# Get baseUrl from .insforge/project.json (the `oss_host` field) after
# `npx @insforge/cli link`. Get the anon key via:
#   npx @insforge/cli secrets get ANON_KEY
#
# NEXT_PUBLIC_INSFORGE_URL is also used server-side as INSFORGE_URL via the
# server-client factory (so we only paste the URL once).
NEXT_PUBLIC_INSFORGE_URL=https://your-appkey.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Server-only copy of the same anon key. The InsForge SSR pattern reads this
# from process.env in server actions and route handlers (no public exposure).
INSFORGE_ANON_KEY=

# Admin/service key — full-access. Server-only. Use sparingly for backend
# tasks that legitimately need to bypass RLS (none in V1; reserved for ops).
INSFORGE_API_KEY=

# ────────────────────────────────────────────────────────────────────────
# OpenRouter — single API key, routes to multiple model families
# ────────────────────────────────────────────────────────────────────────
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Stage 1 extraction model (Claude Opus 4.7 default)
STAGE_1_MODEL=anthropic/claude-opus-4.7

# Stage 1 critic model — MUST be a different family from STAGE_1_MODEL
STAGE_1_CRITIC_MODEL=openai/gpt-5.5

# Stage 2 weighting model (Claude Opus 4.7 default)
STAGE_2_MODEL=anthropic/claude-opus-4.7

# ────────────────────────────────────────────────────────────────────────
# Pipeline limits (per eng review D4)
# ────────────────────────────────────────────────────────────────────────
# Hard cap on cost per run (Stage 1 + critic + Stage 2 cycle), in USD.
# Re-runs start fresh at $0. Default is conservative for the ABB-scale workload.
MAX_COST_USD_PER_RUN=5

# Maximum combined input tokens before Stage 1 will refuse to call.
# Above this, surface a clear error rather than truncating silently.
MAX_INPUT_TOKENS=200000

# ────────────────────────────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────────────────────────────
# Used for OpenRouter HTTP-Referer header (good etiquette + analytics) and
# for OAuth redirect URLs (per InsForge SSR auth docs).
NEXT_PUBLIC_APP_URL=http://localhost:3000
